# Kapot Tracker environment configuration
# Copy this file to .env and adjust the values:
#   cp .env.example .env

# --- Security ---

# JWT signing key. Generate a strong random value, e.g.:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Access token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database ---

# SQLAlchemy database URL.
# SQLite (default for local development, file created automatically).
# Note: docker-compose.yml sets its own DATABASE_URL pointing at the db
# service, so this value only applies when running the backend directly.
DATABASE_URL=sqlite:///./kapot_tracker.db
# PostgreSQL alternative (matches POSTGRES_* below):
# DATABASE_URL=postgresql+psycopg2://kapot_tracker:kapot_tracker@localhost:5432/kapot_tracker_db

# --- CORS ---

# Comma-separated list of allowed origins for the API.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Telegram bot ---

# Токен від @BotFather. Якщо порожній — бот одразу завершується (exit 0).
TELEGRAM_BOT_TOKEN=

# Username бота без @, для deep-link кнопки у Гаражі.
TELEGRAM_BOT_USERNAME=

# Термін дії коду привʼязки акаунта (хвилини).
LINK_CODE_EXPIRE_MINUTES=15

# --- PostgreSQL container (docker compose) ---

POSTGRES_USER=kapot_tracker
POSTGRES_PASSWORD=kapot_tracker
POSTGRES_DB=kapot_tracker_db
