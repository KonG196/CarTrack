# Kapot Tracker environment configuration
# Copy this file to .env and adjust the values:
#   cp .env.example .env

# --- Security ---

# JWT signing key. Generate a strong random value, e.g.:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Access token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database ---

# SQLAlchemy database URL.
# SQLite (default for local development, file created automatically).
# Note: docker-compose.yml sets its own DATABASE_URL pointing at the db
# service, so this value only applies when running the backend directly.
DATABASE_URL=sqlite:///./kapot_tracker.db
# PostgreSQL alternative (matches POSTGRES_* below):
# DATABASE_URL=postgresql+psycopg2://kapot_tracker:kapot_tracker@localhost:5432/kapot_tracker_db

# --- CORS ---

# Comma-separated list of allowed origins for the API.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Telegram bot ---

# Токен від @BotFather. Якщо порожній — бот одразу завершується (exit 0).
TELEGRAM_BOT_TOKEN=

# Username бота без @, для deep-link кнопки у Гаражі.
TELEGRAM_BOT_USERNAME=

# Термін дії коду привʼязки акаунта (хвилини).
LINK_CODE_EXPIRE_MINUTES=15

# --- Файли та бекапи ---

# Каталог для фото записів (створюється автоматично; шлях відносно
# каталогу backend/). У Docker це named volume `uploads`.
UPLOADS_DIR=./uploads

# Каталог, куди складаються бекапи бази даних.
BACKUP_DIR=./backups

# Скільки останніх бекапів зберігати — старіші видаляються при ротації.
BACKUP_KEEP=14

# Telegram chat_id для щоденної доставки бекапу документом.
# УВАГА: бекап містить дані ВСІХ користувачів, тому це має бути
# виключно адмінський чат. Порожнє значення — бекапи створюються
# локально, без надсилання у Telegram.
BACKUP_TELEGRAM_CHAT_ID=

# --- OCR: Gemini fallback (опційно) ---

# Ключ Google AI Studio (https://aistudio.google.com/apikey, є безкоштовний
# рівень без картки). Якщо порожній — розпізнавання чеків працює лише через
# tesseract (офлайн). З ключем: коли tesseract не зміг прочитати чек, фото
# надсилається у Gemini.
GEMINI_API_KEY=

# Модель для fallback (безкоштовний рівень покриває flash-моделі;
# аліас -latest завжди вказує на актуальне покоління).
GEMINI_MODEL=gemini-flash-latest

# --- PostgreSQL container (docker compose) ---

POSTGRES_USER=kapot_tracker
POSTGRES_PASSWORD=kapot_tracker
POSTGRES_DB=kapot_tracker_db
