{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/landing", "destination": "/landing/en/index.html" },
    { "source": "/landing/en", "destination": "/landing/en/index.html" },
    { "source": "/landing/uk", "destination": "/landing/uk/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
